{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Compile",
      "type": "npm",
      "script": "compile",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "Watch",
      "type": "npm",
      "script": "watch",
      "isBackground": true,
      "problemMatcher": ["$tsc-watch"]
    },
    {
      "label": "Package VSIX",
      "type": "shell",
      "command": "npx @vscode/vsce package",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Install VSIX",
      "type": "shell",
      "command": "npx @vscode/vsce package && code --install-extension claude-workspace-*.vsix",
      "group": "build",
      "problemMatcher": []
    }
  ]
}
