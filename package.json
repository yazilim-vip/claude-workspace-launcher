{
  "name": "claude-workspace",
  "displayName": "Claude Workspace",
  "description": "Launch Claude Code sessions with all workspace folders via --add-dir",
  "version": "0.4.6",
  "publisher": "yazilim-vip",
  "license": "MIT",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yazilim-vip/claude-workspace-launcher"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claude-workspace.startSession",
        "title": "Claude: Start Session"
      },
      {
        "command": "claude-workspace.continueSession",
        "title": "Claude: Continue Last Session"
      },
      {
        "command": "claude-workspace.resumeSession",
        "title": "Claude: Resume Session"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^3.0.0"
  }
}
